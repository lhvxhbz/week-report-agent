# 周报终结者 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# LLM Provider: openai, claude, bailian, custom
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Alibaba Bailian (DashScope) Configuration
BAILIAN_API_KEY=sk-your-bailian-api-key
BAILIAN_MODEL=qwen-turbo
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Custom OpenAI-compatible API Configuration
CUSTOM_API_KEY=your-custom-api-key
CUSTOM_MODEL=your-model-name
CUSTOM_BASE_URL=https://your-api-endpoint.com/v1

# Application Settings
# Comma-separated directories to scan for files
SCAN_DIRS=./docs,./notes

# Comma-separated file extensions to include
FILE_EXTENSIONS=.txt,.md,.docx,.pdf

# LLM generation parameters
MAX_TOKENS=4096
TEMPERATURE=0.7

# =============================================================================
# Data Sources (optional – configure only the sources you need)
# =============================================================================

# Google Calendar
# credentials_path: path to Google API service-account or OAuth client JSON
# token_path: (OAuth only) path to store/cache the OAuth token
# calendar_id: calendar to fetch events from (default "primary")
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google_credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=
GOOGLE_CALENDAR_ID=primary

# Feishu (Lark)
# Create a Feishu app at https://open.feishu.cn/app
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# Jira
# Generate an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://yourteam.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=

# Notion
# Create an integration at https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id
