# 周报终结者 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# LLM Provider: openai, claude, bailian, custom
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Alibaba Bailian (DashScope) Configuration
BAILIAN_API_KEY=sk-your-bailian-api-key
BAILIAN_MODEL=qwen-turbo
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Custom OpenAI-compatible API Configuration
CUSTOM_API_KEY=your-custom-api-key
CUSTOM_MODEL=your-model-name
CUSTOM_BASE_URL=https://your-api-endpoint.com/v1

# Application Settings
# Comma-separated directories to scan for files
SCAN_DIRS=./docs,./notes

# Comma-separated file extensions to include
FILE_EXTENSIONS=.txt,.md,.docx,.pdf

# LLM generation parameters
MAX_TOKENS=4096
TEMPERATURE=0.7
